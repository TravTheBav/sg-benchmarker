<%= turbo_frame_tag "build_order_step_#{form.index}" do %>
    <%= form.hidden_field :id %>

    <div>
      <%= form.label :supply, style: "display: block" %>
      <%= form.text_field :supply %>
    </div>
    <div>
      <%= form.label :unit, style: "display: block" %>
      <%= form.text_field :unit %>
    </div>
    <div>
      <%= form.label :description , style: "display: block" %>
      <%= form.text_area :description %>
    </div>

    <%= form.submit "delete step",
        formaction: build_order_step_path(form.index, form.object.id),
        formmethod: :delete,
        formnovalidate: true,
        data: { turbo_frame: "build_order_step_#{form.index}" } %>
    <hr/>
<% end %>
