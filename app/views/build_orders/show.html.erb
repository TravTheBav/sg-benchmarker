<% provide(:title, "#{@user.username} | Build Orders | #{@build_order.name}") %>

<%= render @build_order %>

<% if can? :update, @build_order %>
    <%= link_to 'Edit build order', edit_user_build_order_path(@user, @build_order) %>
<% end %>
<% if can? :destroy, @build_order%>
    <%= link_to 'Delete build order', user_build_order_path(@user, @build_order), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }  %>
<% end %>